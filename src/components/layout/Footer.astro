---
import { t, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---
<footer>
  <div class="footer-inner">
    <p>
      {t(locale, 'common.source')}: <a href="https://data-explorer.oecd.org/" target="_blank" rel="noopener">{t(locale, 'common.oecd_revenue_stats')}</a>
    </p>
    <p class="muted">ObsBudget &mdash; Open-source government budget observatory</p>
  </div>
</footer>

<style>
  footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    margin-top: 3rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem;
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .muted {
    margin-top: 0.5rem;
    opacity: 0.7;
  }

  a {
    color: var(--color-primary);
  }
</style>

---
import { t, getAlternatePath, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const altPath = getAlternatePath(currentPath, locale);
---
<header>
  <div class="header-inner">
    <a href={`/${locale}/`} class="logo">
      <span class="logo-icon">📊</span>
      <span class="logo-text">ObsBudget</span>
    </a>
    <nav>
      <a href={`/${locale}/`}>{t(locale, 'nav.home')}</a>
      <a href={altPath} class="lang-toggle">{t(locale, 'nav.language')}</a>
    </nav>
  </div>
</header>

<style>
  header {
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.25rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .logo:hover {
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  nav a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 500;
  }

  nav a:hover {
    color: var(--color-primary);
    text-decoration: none;
  }

  .lang-toggle {
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 0.85rem;
  }

  .lang-toggle:hover {
    border-color: var(--color-primary);
    color: var(--color-primary) !important;
  }
</style>
